          "studentTask": "Drag the highlighted 5 apples into Mohan's basket."
        },
        {
          "screenId": "raj-calculation",
          "title": "Raj's Turn",
          "animationSteps": [
            "60% means 60 out of every 100.",
            "Write it as 60/100 × 10.",
            "60 × 10 = 600.",
            "600 ÷ 100 = 6.",
            "Raj will give 6 apples."
          ],
          "studentTask": "Drag the highlighted 6 apples into Mohan's basket."
        },
        {
          "screenId": "reflection",
          "title": "Let's Compare",
          "results": [
            "Vipul gave 5 apples.",
            "Raj gave 6 apples."
          ],
          "question": {
            "type": "mcq",
            "text": "Who gave more apples?",
            "options": [
              "Vipul",
              "Raj",
              "Both gave the same number"
            ],
            "correctAnswer": "Raj"
          }
        }
      ],
      "takeaway": "A larger percentage does not always mean a larger quantity. The whole amount also matters."
    },

